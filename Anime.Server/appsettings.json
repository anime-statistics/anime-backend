{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": { "path": "../logs/log-.txt", "rollingInterval": "Day" }
      }
    ]
  },
  "ConnectionStrings": {
    "AnimeDatabase": "Host=localhost:5432;Database=AnimeDatabase;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*"
}
